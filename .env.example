# Voice Agent Configuration
# Copy this file to .env and fill in your values

# ─── Ollama LLM Configuration ─────────────────────────────────────────────────
# Ollama URL (default: http://localhost:11434)
OLLAMA_API_URL=http://localhost:11434

# Ollama model name (installed model, e.g., llama2, neural-chat, mistral, etc.)
OLLAMA_MODEL=neural-chat

# Temperature: 0.0-1.0 (lower = more deterministic, higher = more creative)
OLLAMA_TEMPERATURE=0.7

# ─── Wake Word Configuration ─────────────────────────────────────────────────
WAKE_WORD=hey_jarvis
WAKE_WORD_THRESHOLD=0.15

# ─── Timeout Configuration (in seconds) ───────────────────────────────────────
WAKE_WORD_TIMEOUT=10
CONVERSATION_TIMEOUT=10

# ─── Voice Configuration ──────────────────────────────────────────────────────
# TTS voice name (female, male, etc.)
TTS_VOICE=female

# ─── Logging Level ───────────────────────────────────────────────────────────
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
